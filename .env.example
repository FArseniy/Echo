# Production configuration. Copy this file to .env and use your real domain.
NODE_ENV=production
PORT=3000
PUBLIC_URL=https://echo.example.com
# Exact browser origin, without a trailing slash. Do not use *.
CLIENT_ORIGIN=https://echo.example.com
# Socket.IO rejects payloads larger than this value (bytes).
MAX_SOCKET_PACKET_BYTES=10240
# Private P2P uses STUN first. In the P2P + TURN mode, TURN relays only
# WebRTC-encrypted traffic when a direct path cannot be established.
# Keep TURN_SHARED_SECRET private.
TURN_HOST=trans.example.com
TURN_STUN_PORT=3478
TURN_TLS_PORT=5349
TURN_SHARED_SECRET=replace-with-the-coturn-static-auth-secret
TURN_CREDENTIAL_TTL_MINUTES=30
MAX_ROOM_PARTICIPANTS=20
MAX_MESSAGE_LENGTH=2000
ROOM_TTL_MINUTES=360
EMPTY_ROOM_TTL_MINUTES=10
ROOM_CLEANUP_INTERVAL_MINUTES=5
PIN_ATTEMPT_LIMIT=5
PIN_BLOCK_MINUTES=5
